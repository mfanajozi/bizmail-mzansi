{
  "name": "bizmail-pro",
  "private": true,
  "version": "1.0.0",
  "description": "BizMail Pro - Local-first IMAP/SMTP Client",
  "author": "BizMail Team",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:build": "vite build && electron-builder --win nsis --x64"
  },
  "dependencies": {
    "@ionic/react": "^8.8.3",
    "better-sqlite3": "^12.8.0",
    "electron-log": "^5.4.3",
    "imapflow": "^1.3.1",
    "ionicons": "^8.0.13",
    "nodemailer": "^8.0.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^40.8.5",
    "electron-builder": "^26.8.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.4"
  },
  "build": {
    "appId": "com.bizmail.pro",
    "productName": "BizMail Pro",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "asar": true
  }
}
